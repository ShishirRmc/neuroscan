# ── Application Environment ──────────────────────────────────────────
# Set to 'prod' for Supabase, 'dev' for local Docker
ENVIRONMENT=dev

# ── Database Strategy ───────────────────────────────────────────────
# The code automatically picks the URL based on ENVIRONMENT=dev/prod

# Local Development (Host or Docker)
DEV_DATABASE_URL=postgresql+asyncpg://app_user:app_password@localhost:5432/brain_tumor_app
# DEV_DATABASE_URL=postgresql+asyncpg://app_user:app_password@db:5432/brain_tumor_app

# Production (Supabase / Remote Cloud DB)
PROD_DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@[HOST]:5432/postgres

# Note: If DATABASE_URL is set explicitly, it takes precedence over everything.
# DATABASE_URL=...

# ── Production Pooling (Supabase Recommended) ────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Model Configuration ──────────────────────────────────────────────
MODEL_VERSION=v0.1.0
# Relative or absolute path to the .pt file
# MODEL_PATH=./models/model_v0.1.0.pt

# ── Confidence Policy ───────────────────────────────────────────────
# Adjust sensitivity of "Human Review" gating
HIGH_CONFIDENCE_THRESHOLD=0.85
LOW_CONFIDENCE_THRESHOLD=0.50
TEMPERATURE=1.5

# ── Upload Limits ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
